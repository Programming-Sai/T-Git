{
  "name": "t-git",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "bot": "nodemon --exec \"node --loader ts-node/esm\" src/bot.ts",
    "bot:polling": "cross-env USE_WEBHOOK=false nodemon --exec \"node --loader ts-node/esm\" src/bot.ts",
    "bot:webhook": "cross-env USE_WEBHOOK=true nodemon --exec \"node --loader ts-node/esm\" src/bot.ts",
    "mini": "nodemon --exec \"node --loader ts-node/esm\" src/miniapp/server.ts",
    "dev": "concurrently \"npm run bot:polling\" \"npm run mini\"",
    "dev:webhook": "concurrently \"npm run bot:webhook\" \"npm run mini\"",
    "build": "tsc",
    "postbuild": "shx mkdir -p dist/miniapp && shx cp -r src/miniapp/public dist/miniapp/",
    "start": "concurrently \"npm run bot:polling\" \"npm run mini\"",
    "start:webhook": "concurrently \"npm run bot:webhook\" \"npm run mini\"",
    "start:miniapp": "npm run build && npm run postbuild && node dist/miniapp/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "groq-sdk": "^0.37.0",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "nodemon": "^3.0.2",
    "shx": "^0.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
